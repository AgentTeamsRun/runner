{
  "name": "@rlarua/agentrunner",
  "version": "0.0.3",
  "description": "AgentRunner - AI 에이전트 작업을 폴링하고 실행하는 백그라운드 러너",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "agentrunner": "dist/index.js"
  },
  "files": [
    "dist/**/*",
    "readme.md"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "init": "node dist/index.js init",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "agentteams",
    "runner",
    "ai-agent",
    "automation"
  ],
  "license": "MIT",
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^24.3.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
